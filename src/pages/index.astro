---
import Layout from '../layouts/Layout.astro';
import PortfolioSection from '../components/PortfolioSection.astro';
import { getAllResolvedPhotos, getAllTags } from '../lib/content';

const photos = await getAllResolvedPhotos();
const tags = await getAllTags();
---

<Layout
  title="Viky – Photographer Vienna"
  description="Event photography, portrait photography, and documentary photography in Vienna, Austria. Visual storytelling by Viky."
>
  <!-- 5.1 + 5.2: Hero with SEO keywords -->
  <section class="pt-16 pb-12 sm:pt-20 sm:pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <h1 class="text-5xl sm:text-6xl font-bold tracking-tight mb-4">
        Viky
      </h1>
      <p class="text-lg sm:text-xl text-neutral-600 mb-5">
        Photographer Vienna &mdash; visual storytelling across Austria
      </p>
      <p class="text-neutral-500 max-w-xl leading-relaxed">
        Event photography, portrait photography, and documentary photography
        in Vienna. Capturing honest moments and authentic stories.
      </p>
    </div>
  </section>

  <!-- 5.4: Full portfolio section -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 pb-20">
    <PortfolioSection photos={photos} tags={tags} />
  </section>
</Layout>
