---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PhotoGrid from '../../components/PhotoGrid.astro';
import Lightbox from '../../components/Lightbox.astro';
import { getAlbumWithPhotos } from '../../lib/content';

export async function getStaticPaths() {
  const albums = await getCollection('albums');
  return albums.map((album) => ({ params: { slug: album.id } }));
}

const { slug } = Astro.params;
const result = await getAlbumWithPhotos(slug);

if (!result) return Astro.redirect('/portfolio');

const { data: album, photos } = result;

const siteUrl = Astro.site!.toString().replace(/\/$/, '');
const pageUrl = `${siteUrl}/albums/${slug}`;

const dateStr = album.date
  ? album.date.toLocaleDateString('en-AT', { year: 'numeric', month: 'long' })
  : '';

// 6.3: OG image — use cover photo if set, else first contained photo
const coverPhoto = album.cover
  ? photos.find((p) => p.id === album.cover)
  : photos[0];
const ogImage = coverPhoto ? `${siteUrl}${coverPhoto.image}` : undefined;

// 6.5: CreativeWork (ImageGallery) JSON-LD for album pages
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  name: album.title,
  description: album.description,
  url: pageUrl,
  creator: {
    '@type': 'Person',
    name: 'Viky',
    url: siteUrl,
  },
  ...(album.date && { dateCreated: album.date.toISOString().split('T')[0] }),
  ...(album.location && {
    contentLocation: { '@type': 'Place', name: album.location },
  }),
  // 6.4: Photograph schema for each contained photo
  hasPart: photos.map((p) => ({
    '@type': 'Photograph',
    name: p.title,
    ...(p.description && { description: p.description }),
    contentUrl: `${siteUrl}${p.image}`,
    creator: { '@type': 'Person', name: 'Viky', url: siteUrl },
    ...(p.date && { dateCreated: p.date.toISOString().split('T')[0] }),
    ...(p.location && {
      contentLocation: { '@type': 'Place', name: p.location },
    }),
  })),
};

// 6.9: Ensure description includes location keywords
const metaDescription = album.location?.toLowerCase().includes('vienna')
  ? album.description
  : `${album.description}${album.location ? ` – ${album.location}` : ' – Vienna, Austria'}`;
---

<Layout
  title={`${album.title} – Viky Photography`}
  description={metaDescription}
  ogImage={ogImage}
  ogType="article"
  structuredData={structuredData}
>
  <main class="max-w-7xl mx-auto px-4 sm:px-6 py-12">

    <!-- 4.7 Breadcrumb -->
    <nav aria-label="Breadcrumb" class="mb-8 text-sm text-neutral-500">
      <ol class="flex items-center gap-2">
        <li>
          <a href="/portfolio" class="hover:text-neutral-900 transition-colors">
            Portfolio
          </a>
        </li>
        <li aria-hidden="true">›</li>
        <li class="text-neutral-900 font-medium" aria-current="page">
          {album.title}
        </li>
      </ol>
    </nav>

    <!-- 4.5 Album metadata -->
    <header class="mb-12">
      <h1 class="text-3xl font-bold tracking-tight mb-3">{album.title}</h1>
      <p class="text-neutral-600 text-lg max-w-2xl mb-5">{album.description}</p>
      <div class="flex flex-wrap gap-x-5 gap-y-1 text-sm text-neutral-500">
        {album.location && <span>{album.location}</span>}
        {dateStr && <span>{dateStr}</span>}
        {
          album.tags.length > 0 && (
            <span>{album.tags.join(' · ')}</span>
          )
        }
      </div>
    </header>

    <!-- 4.6 Contained photos -->
    {
      photos.length > 0 ? (
        <>
          <PhotoGrid photos={photos} id="album-gallery" />
          <Lightbox galleryId="album-gallery" />
        </>
      ) : (
        <p class="text-neutral-400">No photos in this album yet.</p>
      )
    }

    <!-- 4.8 Back link -->
    <div class="mt-16 pt-8 border-t border-neutral-100">
      <a
        href="/portfolio"
        class="text-sm text-neutral-500 hover:text-neutral-900 transition-colors"
      >
        ← Back to Portfolio
      </a>
    </div>

  </main>
</Layout>
