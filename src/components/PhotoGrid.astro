---
import type { ResolvedPhoto } from '../lib/content';
import PhotoCard from './PhotoCard.astro';

interface Props {
  photos: ResolvedPhoto[];
  id?: string;
}

const { photos, id = 'portfolio-gallery' } = Astro.props;
---

<div
  id={id}
  class="columns-1 sm:columns-2 lg:columns-3 xl:columns-4"
  style="column-gap: 1rem;"
>
  {photos.map((photo) => <PhotoCard photo={photo} />)}
</div>
